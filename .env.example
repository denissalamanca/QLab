# AFML Quant Lab — environment template (copy to .env; never commit secrets).

# --- Core (prefix AFML_) -------------------------------------------------------
AFML_REDIS_URL=redis://localhost:6379/0
AFML_USE_FAKE_REDIS=false
AFML_REGISTRY_DB_URL=sqlite:///./artifacts/alpha_registry.db

# --- Control plane (prefix AFML_CP_) -------------------------------------------
# CEO PUBLIC key hex — printed by `afml enroll-ceo`. NOT a secret (verification
# only); the private key + TOTP seed live in the OS Keychain.
AFML_CP_CEO_PUBLIC_KEY_HEX=
AFML_CP_REGISTRY_DB_URL=sqlite:///./artifacts/alpha_registry.db
AFML_CP_ACCOUNT_EQUITY=100000
AFML_CP_C95=1.0
AFML_CP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Quickstart ----------------------------------------------------------------
# 1. make install
# 2. uv run afml enroll-ceo        # prints AFML_CP_CEO_PUBLIC_KEY_HEX + otpauth URI
# 3. export AFML_CP_CEO_PUBLIC_KEY_HEX=<value from step 2>
# 4. make redis-up
# 5. uv run afml doctor            # verify data / redis / registry / keychain
