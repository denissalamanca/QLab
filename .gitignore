# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
# NB: lib/ and lib64/ are anchored to the repo root with a leading slash so they
# only match a top-level Python build dir — an unanchored ``lib/`` also matches
# the frontend's ``apps/web/src/lib/`` and silently drops it from commits.
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual envs
.venv/
venv/
env/
ENV/

# uv / poetry
.uv/

# Testing & coverage
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.hypothesis/
.benchmarks/

# Type checking
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# IDE / editors
.idea/
.vscode/
*.swp
*.swo
*~
*.bak
.~lock.*

# OS
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride
._*

# Notebooks
.ipynb_checkpoints/

# Logs (agents, control plane, runtime)
*.log
logs/

# Profiling / perf
*.prof
*.lprof
*.pstats

# Local databases / data
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
data/local/
artifacts/

# Model & feature artifacts (Phase 1+ produces large parquet/pickle outputs locally)
*.pkl
*.joblib
*.onnx
features_*.parquet
bars_*.parquet
ffd_*.parquet
models_local/

# Secrets / keys (Ed25519 keypair, broker tokens, TOTP seed)
.env
.env.*
!.env.example
*.pem
*.key
*.p12
keystore/

# Frontend (Phase 9)
node_modules/
apps/web/dist/
apps/web/.vite/
apps/web/.turbo/
apps/web/coverage/

# Phase sign-off ledgers (recreated per phase, not checked in mid-build)
PHASE_*_SIGNOFF.md

# Local Claude Code agent state (scheduled tasks, transient locks)
.claude/
